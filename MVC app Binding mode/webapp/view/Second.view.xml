<mvc:View controllerName="gergely.albi.mvcapp.controller.Second" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:f="sap.ui.layout.form">
	<Page navButtonPress="onNavPress" showNavButton="true" title="Details">
		<content>
			<ObjectHeader title="{Name}" number="{ID}">
				<attributes>
					<ObjectAttribute text="{Address/Country}"/>
				</attributes>
			</ObjectHeader>
			<f:SimpleForm title="Details" editable="true" layout="ResponsiveGridLayout" emptySpanL="5" labelSpanL="1" class="sapUiLargeMargin" width="auto">
			<f:content>
			<Label text="Name"></Label>
			<Input value="{= ${Name} === 'Sweet Magic' ? ${Name} + ' Yummy' : ${Name} + ' So Yummy' }"></Input>
			<Label text="ID"></Label>
			<Input value="{ID}"></Input>
			<Label text="Country"></Label>
			<Input value="{Address/Country}"></Input>
			</f:content>
			</f:SimpleForm>

			<f:SimpleForm title="Details 3" editable="true" layout="ResponsiveGridLayout" emptySpanL="5" labelSpanL="1" class="sapUiLargeMargin" width="auto">
			<f:content>
			<Label text="Name"></Label>
			<Input value="{namedModel>/SweetsSupplier/4/Name}"></Input>
			<Label text="ID"></Label>
			<Input value="{namedModel>/SweetsSupplier/4/ID}"></Input>
			<Label text="Country"></Label>
			<Input value="{namedModel>/SweetsSupplier/4/Address/Country}"></Input>
			</f:content>
			</f:SimpleForm>
		</content>
	</Page>
</mvc:View>