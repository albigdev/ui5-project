<mvc:View controllerName="gergely.albi.mvcapp.controller.First" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m">
	<Page title="{i18n>title}">
		<content>
			<Table id="suppliersTable" items="{/Suppliers}" class="sapUiResponsiveMargin" width="auto">
				<headerToolbar>
					<Toolbar>
						<Label text="{i18n>numberOfShops}: {viewModel>/count}"/>
					</Toolbar>
				</headerToolbar>
				<columns>
					<Column>
						<header><Text text="{i18n>supplierId}"/></header>
					</Column>
					<Column>
						<header><Text text="{i18n>shopName}"/>
						</header>
					</Column>
					<Column>
						<header><Text text="{i18n>country}"/>
						</header>
					</Column>
				</columns>
				<items>
					<ColumnListItem type="Navigation" press="onListItemPress">
						<cells>
							<ObjectIdentifier text="{SupplierID}"/>
							<ObjectIdentifier text="{
							path:'CompanyName',
							formatter:'.toLowerCase'
							}"/>
							<ObjectIdentifier text="{
							path:'Country',
							formatter:'.toLowerCase'
							}"/>
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
	</Page>
</mvc:View>