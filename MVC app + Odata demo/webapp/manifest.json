{
  "sap.app": {
    "id": "gergely.albi.mvcapp",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "title": "{{title}}",
    "dataSources": {
      "northwind": {
        "uri": "https://services.odata.org/northwind/northwind.svc/",
        "type": "OData",
        "settings": {
          "odataVersion": "2.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "sap-icon://sap-ui5"
    },
    "supportedThemes": [
      "sap_belize",
      "sap_belize_dark",
      "sap_belize_hcb",
      "sap_belize_hcw"
    ]
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "gergely.albi.mvcapp.view.App",
      "type": "XML",
      "id": "app"
    },
    "models": {
      "": {
        "dataSource": "northwind",
        "type": "sap.ui.model.odata.v2.ODataModel",
        "settings": {
          "defaultBindingMode": "TwoWay",
          "useBatch": true
        }
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "gergely.albi.mvcapp.i18n.i18n"
        }
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "gergely.albi.mvcapp.view",
        "controlId": "app",
        "controlAggregation": "pages"
      },
      "routes": [
        {
          "pattern": "",
          "name": "master",
          "target": "First"
        },
        {
          "pattern": "detail/{ID}",
          "name": "detail",
          "target": "Second"
        }
      ],
      "targets": {
        "First": {
          "viewName": "First"
        },
        "Second": {
          "viewName": "Second"
        }
      }
    }
  }
}
