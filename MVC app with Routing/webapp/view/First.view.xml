<mvc:View controllerName="gergely.albi.mvcapp.controller.First" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m">
	<Page title="{i18n>title}">
		<content>
			<Table items="{/SweetsSupplier}" class="sapUiResponsiveMargin" width="auto">
				<headerToolbar>
					<Toolbar>
						<Label text="{i18n>numberOfShops}: {/CountSweets}"/>
					</Toolbar>
				</headerToolbar>
				<columns>
					<Column>
						<header><Text text="Sweet Shop ID"/></header>
					</Column>
					<Column>
						<header><Text text="Sweet Shop {i18n>shopName}"/>
						</header>
					</Column>
				</columns>
				<items>
					<ColumnListItem type="Navigation" press="onListItemPress">
						<cells>
							<ObjectIdentifier text="{ID}"/>
							<ObjectIdentifier text="{
							path:'Name',
							formatter:'.toLowerCase'
							}"/>
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
	</Page>
</mvc:View>